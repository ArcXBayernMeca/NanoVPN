# NanoVPN — environment variables (template). Copy to .env and fill in. NEVER commit .env.

# --- Arc Testnet ---
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
# Optional: authenticated RPC from the ARC CLI (`arc-canteen rpc-url --export`)
# RPC=

# --- Chain constants (reference; usually read from code/config) ---
# ARC_CHAIN_ID=5042002
# USDC_ADDRESS=0x3600000000000000000000000000000000000000           # 6 decimals
# GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9         # EVM testnet
# GATEWAY_MINTER=0x0022222ABE238Cc2C7Bb1f21003F0a260052475B         # EVM testnet

# --- Wallets (do NOT commit real keys; testnet only) ---
SELLER_ADDRESS=
SELLER_PRIVATE_KEY=
BUYER_ADDRESS=
BUYER_PRIVATE_KEY=

# --- AI buyer-brain (model choice open; reference uses OPENAI) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Data store (pick one during design) ---
# DATABASE_URL=                          # Neon Postgres (Vercel Marketplace)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Onboarding pilot ---
# 32-byte hex master key for encrypting per-user spending keys at rest.
# Generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=
# Sponsor wallet that funds new users' spending EOAs (falls back to BUYER_PRIVATE_KEY).
SPONSOR_PRIVATE_KEY=
# Per-user sponsored grant (ERC-20 USDC, 6 dec). Default 0.10. Lower = more demo users per sponsor balance.
USER_GRANT_USD=0.10
# Native USDC-gas (18 dec) sent to each new EOA so it can pay for its own approve + deposit.
USER_GAS_NATIVE=0.05
# Hard cap on the number of wallets the sponsor will fund (drain protection). Capped users must self-fund.
MAX_SPONSORED_WALLETS=100
# SELLER_ADDRESS is also read by the web app (it records human-fetch settlements). Same value as the edge-node's.
